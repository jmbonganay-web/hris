NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Generate each value independently with:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
# Keep both values server-only. Never prefix either variable with NEXT_PUBLIC_.
HRIS_DATA_ENCRYPTION_KEY=
HRIS_DATA_HASH_KEY=

# Server-only Supabase service-role key for scoped employee document storage operations.
# Never prefix this variable with NEXT_PUBLIC_ and never return it from an API.
SUPABASE_SERVICE_ROLE_KEY=

# Phase 10A payroll foundation uses the existing Supabase connection and server-only keys.
# No additional payroll-specific environment variables are required.
